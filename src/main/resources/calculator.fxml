<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="CalculatorController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Enter two numbers:"/>

    <TextField fx:id="number1Field" promptText="Number 1"/>
    <TextField fx:id="number2Field" promptText="Number 2"/>

    <Button text="Calculate Save" onAction="#onCalculateClick"/>

    <Label fx:id="resultLabel"/>

</VBox>